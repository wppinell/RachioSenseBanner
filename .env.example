# RachioSense Pi Dashboard Environment Variables

# Rachio API (required)
# Get from: https://app.rach.io/integrations/developer
RACHIO_API_KEY=your_rachio_api_key_here

# SenseCraft API (required)
# Get from: https://sensecap.seeed.cc/
SENSECRAFT_API_KEY=your_sensecraft_api_key_here
SENSECRAFT_API_SECRET=your_sensecraft_api_secret_here

# Location (optional, defaults to Phoenix AZ)
LATITUDE=33.4484
LONGITUDE=-112.0740
TIMEZONE=America/Phoenix

# Server Port (optional, default: 8080)
# PORT=8080
